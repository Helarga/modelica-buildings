simulateModel("Buildings.Applications.DHC.EnergyTransferStations.Examples.Source_Load_PumpsController", method="dassl",
tolerance=1e-6, stopTime=1000, resultFile="Source_LoadPumpsControllerBlock");
createPlot(id = 1,
