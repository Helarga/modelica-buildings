   autoscale = true,
   autoerase = true,
   autoreplot = true,
   grid = true,
   color = true,
   leftTitleType = 1,
   bottomTitleType = 1);
createPlot(id = 2,
   position = {670, 10, 600, 450},
   y = {"pumCon.disCooVal","pumCon.disHeaVal"},
   autoscale = true,
   autoerase = true,
