simulateModel("Buildings.Applications.DHC.EnergyTransferStations.Examples.HeatpumpControllerHeaOnly", method="dassl",
 tolerance=1e-6, stopTime=21600, resultFile="HeatpumpControllerHeaOnly");
createPlot(id = 1,
   position = {60, 10, 600, 450},
   y = {"valEva.port_1.m_flow","valEva.port_2.m_flow","valEva.port_3.m_flow","pumEva1.m_flow"  },
   autoscale = true,
   autoerase = true,
   autoreplot = true,
   grid = true,
   color = true,
   leftTitleType = 1,
   bottomTitleType = 1);
createPlot(id = 1,
   position = {60, 10, 600, 450},
   y = {"splVal2.port_2.m_flow"  },
   subPlot = 2,
   autoscale = true,
   autoerase = true,
   autoreplot = true,
   grid = true,
   color = true,
   leftTitleType = 1,
   bottomTitleType = 1);
createPlot(id = 2,
   position = {670, 10, 600, 450},
