// Simulate
simulateModel("Buildings.Applications.DHC.CentralPlants.Heating.Generation4.Validation.MappingBoilerPLRToMassFlow",
                method="Cvode",
                stopTime=3600, 
                tolerance=1e-06, 
                resultFile="MappingBoilerPLRToMassFlow");
// Plot
createPlot(id=1, 
  position = {75, 70,1200, 980}, 
  y={"boi.sta_a.T","boi.sta_b.T"},
  grid=true, 
  autoscale = true,
  autoerase = true,
  autoreplot = true,
  color = true);

createPlot(id=1,
  y={"boi.PLR[1]","boi.PLR[2]"}, 
  grid=true, 
  subPlot=2,
  autoscale = true,
  autoerase = true,
  autoreplot = true,
  color = true);
